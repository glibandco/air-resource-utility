#!/bin/bash
# Resource Monitor.app launcher.
# Runs python3 menubar.py from the bundled Resources/ directory, silently.
# All output goes to ~/Library/Logs/ResourceMonitor.log for debugging.

set -u

LOG="$HOME/Library/Logs/ResourceMonitor.log"
mkdir -p "$(dirname "$LOG")"

# All output below goes to the log file (no Terminal window).
exec >>"$LOG" 2>&1
echo "==== $(date) — launching Resource Monitor ===="

HERE="$(cd "$(dirname "$0")" && pwd)"
RES="$HERE/../Resources"
cd "$RES"

# Find python3. Prefer system Python on macOS.
RAW_PY="$(command -v python3 || true)"
if [ -z "$RAW_PY" ]; then
    osascript -e 'display dialog "Python 3 is required.\n\nInstall the Xcode Command Line Tools by opening Terminal and running:\n\n    xcode-select --install" buttons {"OK"} default button "OK" with icon caution with title "Resource Monitor"' >/dev/null 2>&1 || true
    exit 1
fi

# The framework Python.app (used by rumps/AppKit for the menu bar) always runs
# as x86_64 on this machine. Pin the launcher to x86_64 so pip installs and
# imports use the same slice that will actually execute.
PY="arch -x86_64 $RAW_PY"
echo "Python: $RAW_PY ($(arch -x86_64 "$RAW_PY" --version 2>&1), forced x86_64)"

# First-run / one-time dependency install. Idempotent — pip is a no-op if
# everything is already at the pinned version.
DEPS=(psutil "pyobjc-core<11" "pyobjc-framework-Cocoa<11" rumps)
NEED_INSTALL=0
for mod in psutil rumps AppKit; do
    if ! arch -x86_64 "$RAW_PY" -c "import $mod" >/dev/null 2>&1; then
        NEED_INSTALL=1
        break
    fi
done

if [ "$NEED_INSTALL" = "1" ]; then
    echo "Installing dependencies (one-time)..."
    osascript -e 'display notification "Installing dependencies — this happens once and takes about a minute." with title "Resource Monitor" subtitle "First launch"' >/dev/null 2>&1 || true

    arch -x86_64 "$RAW_PY" -m pip install --user --quiet "${DEPS[@]}" 2>>"$LOG" \
        || arch -x86_64 "$RAW_PY" -m pip install --user --quiet --break-system-packages "${DEPS[@]}" 2>>"$LOG" \
        || arch -x86_64 "$RAW_PY" -m pip install --user "${DEPS[@]}"

    osascript -e 'display notification "Look at the top-right of your screen for CPU %" with title "Resource Monitor" subtitle "Ready"' >/dev/null 2>&1 || true
fi

echo "Starting menubar.py..."
exec arch -x86_64 "$RAW_PY" menubar.py
